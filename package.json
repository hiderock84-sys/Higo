{
  "name": "higonoie",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "verify:header": "node scripts/verify-site-chrome-sticky.mjs",
    "build": "npm run verify:header && vite build && node scripts/prepare-pages-output.mjs",
    "build:pages": "npm run build",
    "pages:build": "npm run build",
    "build:prod": "npm run build",
    "build:cloudflare": "npm run build",
    "build:hidonoie": "npm run build",
    "build:higono-ie": "npm run build",
    "build:static": "npm run build",
    "build:production": "npm run build",
    "cf:build": "npm run build",
    "generate": "npm run build",
    "export": "npm run build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && node scripts/setup-and-deploy.mjs",
    "deploy:prod": "npm run build && CLOUDFLARE_PAGES_PROJECT=higo node scripts/setup-and-deploy.mjs",
    "package:dist": "node scripts/package-dist-zip.mjs",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "vite": "^5.0.0",
    "wrangler": "^3.78.0"
  }
}
